# Copy this file to .env.openai and fill your own key.
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY

# Optional overrides
RESILIENCEOS_OPENAI_MODEL=gpt-4o-mini
RESILIENCEOS_OPENAI_TEMPERATURE=0.2
RESILIENCEOS_OPENAI_MAX_TOKENS=260
RESILIENCEOS_OPENAI_TIMEOUT_SECONDS=20

# Optional: force deterministic fallback even if key exists
# RESILIENCEOS_DISABLE_OPENAI_EXPLAIN=true
